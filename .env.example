# App
SECRET_KEY=cambia-esto-por-una-clave-segura
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS (separados por coma)
ALLOWED_ORIGINS=http://localhost:3000,https://tu-frontend.vercel.app

# Base de datos Supabase PostgreSQL
# Obten la URL en: Supabase > Settings > Database > Connection string > URI
# Formato: postgresql://postgres:[TU_PASSWORD]@db.ucacmeyfybjdntieudsm.supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:[TU_PASSWORD]@db.ucacmeyfybjdntieudsm.supabase.co:5432/postgres

# Supabase Keys
SUPABASE_URL=https://ucacmeyfybjdntieudsm.supabase.co
SUPABASE_ANON_KEY=tu-anon-key-aqui
SUPABASE_SERVICE_KEY=tu-service-role-key-aqui

# DIAN
DIAN_AMBIENTE=2
NIT_EMPRESA=900000000
RAZON_SOCIAL=FINPRO CAPITAL SAS
CERT_PATH=./certs/certificado.p12
CERT_PASSWORD=password-del-certificado
SOFTWARE_ID=software-id-dian
